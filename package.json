{
  "name": "myinc-social-media-ai",
  "version": "2.0.0-local-engine-v6.2",
  "description": "MYINC Social Media AI v2 — frontend base preservado, Supabase central e motor local EXE.",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:host": "vite dev --host 0.0.0.0",
    "build": "vite build && node scripts/ensure-desktop-index.mjs",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "preview:host": "vite preview --host 0.0.0.0 --port 4173",
    "start": "npm run preview:host",
    "production": "npm run build",
    "hosting:build": "npm ci && npm run build",
    "hosting:start": "npm run preview:host",
    "lint": "eslint src engine electron server scripts tests supabase/functions",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "engine:exe": "npx @yao-pkg/pkg engine/runtime/main-loop.mjs --targets node20-win-x64 --output dist/MYINC-Engine.exe",
    "verify": "npm run typecheck && npm run lint && npm run build",
    "local": "node server/local-api.mjs",
    "local:api": "node server/local-api.mjs",
    "local:reset": "node -e \"const fs=require('fs');fs.rmSync('data/myinc-local-db.json',{force:true});console.log('Banco local resetado. Rode npm run local.')\"",
    "local:check": "node --check server/local-api.mjs && npm run typecheck && npm run build",
    "local:backup-dir": "node -e \"console.log(require('path').resolve('data/backups'))\"",
    "desktop:dev": "npm run local",
    "desktop:build": "npm run build && npx electron-builder --win nsis --x64",
    "desktop:pack": "npm run build && node scripts/package-client.mjs",
    "desktop:setup": "npm install -D electron electron-builder",
    "verify:server": "node --check server/local-api.mjs",
    "web:dev": "vite dev",
    "web:build": "vite build",
    "engine:dev": "node engine/runtime/main-loop.mjs",
    "engine:check": "node --check engine/runtime/main-loop.mjs && node --check engine/processors/job-processor.mjs && node --check engine/renderers/design-renderer-v2.mjs && node --check engine/openai/openai-client.mjs",
    "test:v2": "node tests/v2-frontend-base-restored.test.mjs && node tests/v2-no-heavy-vercel-worker.test.mjs && node tests/v2-no-simplified-frontend.test.mjs && node tests/v2-edge-contract.test.mjs && node tests/v2-engine-contract.test.mjs && node tests/v2-sql-contract.test.mjs && node tests/v2-no-secret-leak.test.mjs && node --check engine/runtime/main-loop.mjs",
    "v2:verify": "npm run typecheck && npm run build && npm run test:v2",
    "desktop:v2:dev": "npm run build && electron .",
    "desktop:v2:build": "npm run build && npx electron-builder --win nsis --x64",
    "v6:verify": "npm run typecheck && node scripts/verify-v6-contracts.mjs && npm run test:v2 && npm run build",
    "deps:clean": "node -e \"const fs=require('fs'); for (const p of ['node_modules','package-lock.json']) fs.rmSync(p,{recursive:true,force:true}); console.log('Dependencias antigas removidas. Rode npm install.')\"",
    "deps:install": "npm install",
    "creative:v7:check": "npm run engine:check && node --check electron/main.cjs && node --check electron/engine-process.cjs && node --check electron/tray.cjs && node scripts/verify-creative-journey.mjs",
    "client:package": "npm run build && npm run creative:v7:check && node scripts/package-client.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-start": "^1.167.50",
    "@tanstack/router-plugin": "^1.167.28",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.6.5",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^3.24.2",
    "sharp": "^0.34.3",
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@lovable.dev/vite-tanstack-config": "2.1.1",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@yao-pkg/pkg": "^6.20.0",
    "electron": "^37.7.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "nitro": "3.0.260429-beta",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "br.com.myinc.socialmediaai",
    "productName": "MYINC Social Media AI",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "engine/**/*",
      "src/assets/**/*",
      "templates/**/*",
      "assets/**/*",
      ".env.engine.example"
    ],
    "extraResources": [
      {
        "from": "dist/client",
        "to": "dist/client"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asarUnpack": [
      "engine/**/*",
      "src/assets/**/*",
      "templates/**/*",
      "assets/**/*"
    ]
  },
  "overrides": {
    "@lovable.dev/vite-tanstack-config": "2.1.1"
  }
}
