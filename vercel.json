{
  "framework": null,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "NITRO_PRESET=vercel npm run build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
